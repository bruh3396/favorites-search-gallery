{
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "esbuild": "^0.25.2",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^9.25.1",
    "globals": "^15.15.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.3"
  },
  "eslintIgnore": [
    "dist",
    "node_modules"
  ],
  "scripts": {
    "build": "node scripts/bin/userscript_builder || (tsc --project scripts/tsconfig.json && node scripts/bin/userscript_builder)",
    "test": "vitest --run",
    "build-and-test": "npm run build && npm run test",
    "visualize": "npx esbuild-visualizer --metadata dist/meta.json --template treemap --filename .\\dist\\stats.html --open",
    "embed-ts": "(node scripts/bin/static_ts_embedder.js || (tsc --project scripts/tsconfig.json && node scripts/bin/static_ts_embedder.js)) && npm run build && npm run test",
    "compile-scripts": "tsc --project scripts/tsconfig.json",
    "build-performance": "esbuild src/tests/performance.ts --bundle --format=iife --platform=browser --outfile=dist/performance.js"
  },
  "dependencies": {
    "strip-ansi": "^7.1.0"
  }
}